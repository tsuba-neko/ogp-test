{
  "file_scan_exclusions": ["**/routeTree.gen.ts"],
  "preferred_line_length": 80,
  "tab_size": 2,
  "edit_predictions": {
    "provider": "copilot"
  },
  "format_on_save": "on",
  "languages": {
    "JavaScript": {
      "language_servers": [
        "biome",
        "!eslint",
        "!tsgo",
        // "!vtsls",
        "!typescript-language-server",
        "..."
      ],
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "TypeScript": {
      "language_servers": [
        "biome",
        "!eslint",
        "!tsgo",
        //"!vtsls",
        "!typescript-language-server",
        "..."
      ],
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "TSX": {
      "language_servers": [
        "biome",
        "!eslint",
        "!tsgo",
        // "!vtsls",
        "!typescript-language-server",
        "..."
      ],
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "JSON": {
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "JSONC": {
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    }
  }
}
